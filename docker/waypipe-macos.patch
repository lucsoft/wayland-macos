new file mode 100644
index 0000000..9efe640
--- /dev/null
+++ b/src/compat.rs
@@ -0,0 +1,153 @@
+//! Small portability shim so waypipe's client side builds on macOS (Darwin),
+//! which lacks `memfd_create`, `pipe2`, and `ppoll`. These implementations are
+//! cross-platform (they also work on Linux) and only cover what waypipe uses.
+
+use nix::errno::Errno;
+use nix::fcntl::OFlag;
+use nix::poll::{PollFd, PollTimeout};
+use nix::sys::signal::SigSet;
+use nix::sys::time::TimeSpec;
+use std::ffi::CStr;
+use std::os::fd::{FromRawFd, OwnedFd};
+
+/// Anonymous, resizable, mmap-able fd. On Linux waypipe uses `memfd_create`;
+/// here we open a regular file and immediately `unlink` it. Crucially this must
+/// be a regular file, NOT a POSIX shm object: macOS `shm_open` objects can only
+/// be sized once, and waypipe grows buffers with `ftruncate` (e.g. when a client
+/// resizes an shm pool), which would fail with EINVAL on shm.
+pub fn memfd_create(_name: &CStr) -> nix::Result<OwnedFd> {
+    use std::sync::atomic::{AtomicU32, Ordering};
+    static CTR: AtomicU32 = AtomicU32::new(0);
+    let n = CTR.fetch_add(1, Ordering::Relaxed);
+    let pid = unsafe { nix::libc::getpid() };
+    let dir = std::env::var("XDG_RUNTIME_DIR")
+        .or_else(|_| std::env::var("TMPDIR"))
+        .unwrap_or_else(|_| "/tmp".to_string());
+    let path = format!("{dir}/wp-{pid}-{n}\0");
+    let cpath = path.as_ptr() as *const nix::libc::c_char;
+    let fd = unsafe {
+        nix::libc::open(
+            cpath,
+            nix::libc::O_RDWR | nix::libc::O_CREAT | nix::libc::O_EXCL,
+            0o600,
+        )
+    };
+    if fd < 0 {
+        return Err(Errno::last());
+    }
+    // Detach the name; the fd stays valid and the file is freed on last close.
+    unsafe { nix::libc::unlink(cpath) };
+    Ok(unsafe { OwnedFd::from_raw_fd(fd) })
+}
+
+/// `pipe2` replacement: `pipe()` followed by explicit flag setting.
+pub fn pipe2(flags: OFlag) -> nix::Result<(OwnedFd, OwnedFd)> {
+    use std::os::fd::AsRawFd;
+    let mut fds = [0 as nix::libc::c_int; 2];
+    if unsafe { nix::libc::pipe(fds.as_mut_ptr()) } != 0 {
+        return Err(Errno::last());
+    }
+    let r = unsafe { OwnedFd::from_raw_fd(fds[0]) };
+    let w = unsafe { OwnedFd::from_raw_fd(fds[1]) };
+    for fd in [r.as_raw_fd(), w.as_raw_fd()] {
+        if flags.contains(OFlag::O_CLOEXEC) {
+            let cur = unsafe { nix::libc::fcntl(fd, nix::libc::F_GETFD) };
+            unsafe { nix::libc::fcntl(fd, nix::libc::F_SETFD, cur | nix::libc::FD_CLOEXEC) };
+        }
+        if flags.contains(OFlag::O_NONBLOCK) {
+            let cur = unsafe { nix::libc::fcntl(fd, nix::libc::F_GETFL) };
+            unsafe { nix::libc::fcntl(fd, nix::libc::F_SETFL, cur | nix::libc::O_NONBLOCK) };
+        }
+    }
+    Ok((r, w))
+}
+
+/// `ppoll` replacement built on `poll`. The atomic signal-mask swap is dropped
+/// (macOS has no `ppoll`); waypipe also uses a self-pipe to wake on signals, so
+/// this is adequate for the client side. waypipe only ever calls it with a
+/// `None` (block) or zero timeout.
+pub fn ppoll(
+    fds: &mut [PollFd],
+    timeout: Option<TimeSpec>,
+    _sigmask: Option<SigSet>,
+) -> nix::Result<nix::libc::c_int> {
+    let to = match timeout {
+        None => PollTimeout::NONE,
+        Some(ts) => {
+            let ms = (ts.tv_sec() as i64) * 1000 + (ts.tv_nsec() as i64) / 1_000_000;
+            u16::try_from(ms.max(0)).map(PollTimeout::from).unwrap_or(PollTimeout::MAX)
+        }
+    };
+    nix::poll::poll(fds, to)
+}
+
+/// Client-side macOS build does not fork the application, so there are no child
+/// processes to reap; `waitid(P_ALL, WNOWAIT)` (unavailable in nix on macOS) is
+/// emulated as "nothing changed".
+pub fn reap_any() -> nix::Result<nix::sys::wait::WaitStatus> {
+    Ok(nix::sys::wait::WaitStatus::StillAlive)
+}
+
+/// Drop-in for `nix::sys::socket` that supplies the `SOCK_CLOEXEC` /
+/// `SOCK_NONBLOCK` flags macOS lacks by applying them via `fcntl` after
+/// `socket()`/`socketpair()`.
+pub mod sock {
+    pub use nix::sys::socket::*;
+    use nix::sys::socket::SockFlag as NixSockFlag;
+    use std::os::fd::{AsRawFd, OwnedFd, RawFd};
+
+    #[derive(Clone, Copy, PartialEq, Eq)]
+    pub struct SockFlag(pub i32);
+
+    impl SockFlag {
+        pub const SOCK_CLOEXEC: SockFlag = SockFlag(1);
+        pub const SOCK_NONBLOCK: SockFlag = SockFlag(2);
+        pub fn empty() -> SockFlag {
+            SockFlag(0)
+        }
+        pub fn contains(self, other: SockFlag) -> bool {
+            (self.0 & other.0) == other.0
+        }
+    }
+
+    impl std::ops::BitOr for SockFlag {
+        type Output = SockFlag;
+        fn bitor(self, other: SockFlag) -> SockFlag {
+            SockFlag(self.0 | other.0)
+        }
+    }
+
+    fn apply(fd: RawFd, flags: SockFlag) {
+        if flags.contains(SockFlag::SOCK_CLOEXEC) {
+            let cur = unsafe { nix::libc::fcntl(fd, nix::libc::F_GETFD) };
+            unsafe { nix::libc::fcntl(fd, nix::libc::F_SETFD, cur | nix::libc::FD_CLOEXEC) };
+        }
+        if flags.contains(SockFlag::SOCK_NONBLOCK) {
+            let cur = unsafe { nix::libc::fcntl(fd, nix::libc::F_GETFL) };
+            unsafe { nix::libc::fcntl(fd, nix::libc::F_SETFL, cur | nix::libc::O_NONBLOCK) };
+        }
+    }
+
+    pub fn socket<T: Into<Option<SockProtocol>>>(
+        domain: AddressFamily,
+        ty: SockType,
+        flags: SockFlag,
+        protocol: T,
+    ) -> nix::Result<OwnedFd> {
+        let fd = nix::sys::socket::socket(domain, ty, NixSockFlag::empty(), protocol)?;
+        apply(fd.as_raw_fd(), flags);
+        Ok(fd)
+    }
+
+    pub fn socketpair<T: Into<Option<SockProtocol>>>(
+        domain: AddressFamily,
+        ty: SockType,
+        protocol: T,
+        flags: SockFlag,
+    ) -> nix::Result<(OwnedFd, OwnedFd)> {
+        let (a, b) = nix::sys::socket::socketpair(domain, ty, protocol, NixSockFlag::empty())?;
+        apply(a.as_raw_fd(), flags);
+        apply(b.as_raw_fd(), flags);
+        Ok((a, b))
+    }
+}
